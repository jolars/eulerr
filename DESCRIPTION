Package: eulerr
Title: Area-Proportional Euler and Venn Diagrams
Version: 8.1.1
Authors@R: c(person("Johan", "Larsson", email = "johan@jolars.co",
                    role = c("aut", "cre", "cph"),
                    comment = c(ORCID = "0000-0002-4029-5945")),
             person("A. Jonathan R.", "Godfrey", role = "ctb"),
